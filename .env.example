# =============================================================================
# Diazites AI — .env.example
# Copy to .env.local and fill in. NEVER commit real secrets to git.
#
# If any keys ever land in git history (incl. earlier versions of this file),
# rotate them in the respective provider dashboard immediately.
# =============================================================================

# --- Supabase --------------------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...REPLACE_ME
SUPABASE_SERVICE_KEY=eyJhbGciOi...REPLACE_ME

# --- App ------------------------------------------------------------------
# Canonical browser-facing URL. Also set this exact value as Supabase
# Authentication → URL Configuration → Site URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI -------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-REPLACE_ME

# --- Email (Resend) -------------------------------------------------------
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=Diazites AI <noreply@diazites.com>
# Comma-separated admin notification recipients (agent activations, etc.)
ADMIN_NOTIFICATION_EMAILS=

# --- SMS (Twilio - optional) ----------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- AgentMail HTTP fallback (optional) -----------------------------------
AGENTMAIL_API_URL=
AGENTMAIL_API_KEY=

# --- Stripe (optional - leave empty until billing goes live) --------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_DOMINATION=

# --- Cron (optimization sweep) --------------------------------------------
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
# to /api/cron/optimize. Required in production. In dev, leave blank to
# allow unauthenticated calls.
CRON_SECRET=

# --- Ads engine (optional - per platform OAuth) ---------------------------
# Each platform is gated at runtime; leave a group empty to keep that
# connector in stub mode.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URL=

GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URL=

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URL=

MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_REDIRECT_URL=

# --- Zernio (multi-platform social + ads broker) --------------------------
# Per-business API keys are entered in /dashboard/ads and stored in
# `ad_accounts.access_token` with `platform = 'zernio'` (RLS-isolated per
# business). The base URL only needs to be set if you point at a staging
# environment; production defaults to https://zernio.com/api/v1.
ZERNIO_API_BASE_URL=
# Used ONLY by the Cursor IDE MCP config (.cursor/mcp.json) so the agent
# itself can call Zernio tools during development. Per-tenant keys for the
# live app come from the UI, never from this env.
ZERNIO_API_KEY=
