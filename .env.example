# =============================================================================
# Diazites AI — .env.example
# Copy to .env.local and fill in. NEVER commit real secrets to git.
#
# If any keys ever land in git history (incl. earlier versions of this file),
# rotate them in the respective provider dashboard immediately.
# =============================================================================

# --- Supabase --------------------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...REPLACE_ME
SUPABASE_SERVICE_KEY=eyJhbGciOi...REPLACE_ME

# --- App ------------------------------------------------------------------
# Canonical browser-facing URL. Also set this exact value as Supabase
# Authentication → URL Configuration → Site URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (Supabase dashboard) --------------------------------------------
# Redirect URLs (add production URL too):
#   http://localhost:3000/auth/callback
#   https://YOUR-DOMAIN.com/auth/callback
# Social sign-in: enable in Supabase Authentication → Providers (Google, Facebook),
# then set matching flags here so buttons appear in the app (see /admin/setup):
# NEXT_PUBLIC_AUTH_PROVIDER_GOOGLE=true
# NEXT_PUBLIC_AUTH_PROVIDER_FACEBOOK=true
# Branded confirmation emails (stop "from Supabase"):
#   Authentication → SMTP → use Resend (smtp.resend.com, user: resend, pass: RESEND_API_KEY)
#   Sender: Diazites AI <noreply@diazites.com>
#   Authentication → Email Templates → set subjects/bodies to "Diazites AI" branding

# Homepage hero background (YouTube). Full URL or 11-char ID.
NEXT_PUBLIC_HERO_YOUTUBE_ID=Fyo6vnM8BBk
# Or paste a youtu.be / watch link:
# NEXT_PUBLIC_HERO_VIDEO_URL=https://youtu.be/Fyo6vnM8BBk
# Optional MP4 fallback only (direct .mp4 file URL):
# NEXT_PUBLIC_HERO_VIDEO_URL=https://videos.pexels.com/video-files/3195394/3195394-uhd_2560_1440_25fps.mp4

# --- AI -------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-REPLACE_ME

# --- Email (Resend) -------------------------------------------------------
RESEND_API_KEY=re_BHVKDjzd_7apuFvvRoQ4zD2Qx7Xc1Sg2z
RESEND_FROM_EMAIL=Diazites AI <noreply@diazites.com>
# Comma-separated admin notification recipients (agent activations, etc.)
ADMIN_NOTIFICATION_EMAILS=

# --- Platform admin (first operator on production) ------------------------
# /admin requires a row in Supabase public.admin_users for your auth user.
# Option A — Supabase SQL Editor (fastest):
#   insert into public.admin_users (user_id, role)
#   select id, 'admin' from public.users where email ilike 'you@company.com'
#   on conflict (user_id) do nothing;
# Option B — env bootstrap (set on Vercel, redeploy, sign out/in or click Retry on dashboard):
# PLATFORM_BOOTSTRAP_ADMIN_EMAIL=you@company.com
# Optional: allow bootstrap even when admins already exist
# PLATFORM_BOOTSTRAP_ALLOW_IF_ADMINS_EXIST=true
# Option C — one-time HTTP bootstrap (set secret, call once, then remove):
# PLATFORM_BOOTSTRAP_SECRET=long-random-string
# POST /api/platform/bootstrap-admin  Authorization: Bearer <secret>  {"email":"you@company.com"}

# --- SMS (Twilio - optional) ----------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- AgentMail HTTP fallback (optional) -----------------------------------
AGENTMAIL_API_URL=
AGENTMAIL_API_KEY=

# --- Stripe (optional - leave empty until billing goes live) --------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_DOMINATION=

# --- Revenue webhooks (Stripe uses STRIPE_WEBHOOK_SECRET above) -----------
# Optional global Shopify signing secret (or set per-store in Organization → Workspace)
SHOPIFY_WEBHOOK_SECRET=

# --- Cron (optimization sweep) --------------------------------------------
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
# to /api/cron/optimize. Required in production. In dev, leave blank to
# allow unauthenticated calls.
CRON_SECRET=

# --- Ads engine (optional - per platform OAuth) ---------------------------
# Each platform is gated at runtime; leave a group empty to keep that
# connector in stub mode.
META_APP_ID=
META_APP_SECRET=
# e.g. http://localhost:3000/api/ads/oauth/callback
META_REDIRECT_URL=

GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# e.g. http://localhost:3000/api/ads/oauth/callback (must match Google Cloud OAuth client)
GOOGLE_ADS_REDIRECT_URL=

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URL=

MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_REDIRECT_URL=

# --- Zernio (ads + social, 14 platforms) ---
# API key from https://zernio.com/dashboard/api-keys
# Also wire Cursor MCP via .cursor/mcp.json (see https://docs.zernio.com/mcp)
ZERNIO_API_KEY=

# --- Diazites MCP (external agents: OpenClaw, Hermes, Cursor, etc.) ---
# Tokens are created per business at /dashboard/agents (not env-based).
# Endpoint: ${NEXT_PUBLIC_APP_URL}/api/mcp  Authorization: Bearer diaz_mcp_...
# Requires SUPABASE_SERVICE_KEY for token validation on the MCP route.
