# Copy this file to .env.local and fill in values from:
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-secret

# Public site URL (auth emails, Stripe redirects). On Vercel set to https://YOUR_DEPLOYMENT.vercel.app or your custom domain.
# If unset on Vercel, the app falls back to https://VERCEL_URL when available.
NEXT_PUBLIC_APP_URL=http://localhost:3000

RESEND_API_KEY=
OPENAI_API_KEY=

# Optional: comma-separated emails for internal alerts (agents, onboarding)
ADMIN_NOTIFICATION_EMAILS=

# Stripe (billing — create Prices in Stripe Dashboard, paste IDs here)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_DOMINATION=

# Twilio SMS (optional — automations with action_type sms)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AgentMail or other HTTP SMS provider (full POST URL + bearer token)
AGENTMAIL_API_URL=
AGENTMAIL_API_KEY=
